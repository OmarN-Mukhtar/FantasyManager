# Git LFS configuration for large binary files only
# JSON and CSV must NOT be in LFS - they need to be readable text files
*.faiss filter=lfs diff=lfs merge=lfs -text
*.pkl filter=lfs diff=lfs merge=lfs -text
vector_db/*.faiss filter=lfs diff=lfs merge=lfs -text
vector_db/*.pkl filter=lfs diff=lfs merge=lfs -text
